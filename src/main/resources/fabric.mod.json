{
	"schemaVersion": 1,
	"id": "minegit",
	"version": "${version}",
	"name": "MineGIT",
	"description": "Minecraft cloud save system using the power of GitHub!",
	"authors": [
		"ModMonster"
	],
	"contact": {
		"homepage": "https://youtube.com/modmonster",
		"sources": "https://github.com/modmonster/MineGIT",
        "issues": "https://github.com/modmonster/MineGIT/issues"
	},
	"license": "MIT",
	"icon": "assets/minegit/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"ca.modmonster.minegit.MineGIT"
		],
        "modmenu": [
            "ca.modmonster.minegit.extra.ModMenuImplementation"
        ]
	},
	"mixins": [
		"minegit.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
    "custom": {
        "modmenu": {
            "links": {
                "modmenu.discord": "https://discord.gg/45tjuM8"
            }
        }
    }
}